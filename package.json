{
  "name": "cusown",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "overrides": {
    "dompurify": "3.3.3",
    "immutable": "^4.3.8"
  },
  "scripts": {
    "predev": "node scripts/infrastructure/check-node-version.js",
    "prebuild": "node scripts/infrastructure/check-node-version.js",
    "dev": "next dev --webpack",
    "dev:polling": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "build:strict": "node scripts/infrastructure/strict-build.js",
    "build:fresh": "node scripts/infrastructure/clean-build-artifacts.js && npm run build:strict",
    "start": "next start",
    "lint": "next lint",
    "lint:strict": "eslint app components lib services repositories proxy.ts --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "security": "npm audit --omit=dev",
    "security:audit": "npm audit --audit-level=high --omit=dev",
    "security:deps": "npm audit --audit-level=high --omit=dev",
    "security:gitleaks:staged": "node scripts/infrastructure/run-detect-secrets.js --staged",
    "security:gitleaks": "node scripts/infrastructure/run-detect-secrets.js",
    "security:custom:staged": "node scripts/infrastructure/validate-security-and-quality.js --staged",
    "security:custom:repo": "node scripts/infrastructure/validate-security-and-quality.js",
    "security:custom:baseline:update": "node scripts/infrastructure/validate-security-and-quality.js --write-baseline",
    "validate": "npm run lint:strict && npm run type-check && npm run build:strict",
    "format": "ts-node --project scripts/tsconfig.json scripts/infrastructure/format-all.ts",
    "format:check": "prettier --check --config config/quality/prettier.config.js \"app/**/*.{js,jsx,ts,tsx,json,css,md}\" \"components/**/*.{js,jsx,ts,tsx,json,css,md}\" \"lib/**/*.{js,jsx,ts,tsx,json,css,md}\" \"config/**/*.{js,jsx,ts,tsx,json}\"",
    "verify-env": "ts-node --project scripts/tsconfig.json scripts/verify-env.ts",
    "local-ci": "ts-node --project scripts/tsconfig.json scripts/infrastructure/local-ci.ts",
    "prepare": "husky",
    "clean": "node scripts/infrastructure/clean-build-artifacts.js",
    "clean:all": "node scripts/infrastructure/clean-build-artifacts.js",
    "dev:clean": "npm run clean:all && npm run dev",
    "dev:fresh": "npm run clean && npm run dev",
    "guard:all": "node scripts/infrastructure/run-enterprise-guard.js",
    "precommit:strict": "npx lint-staged --config config/quality/lint-staged.config.js && npm run lint:strict && npm run typecheck && npm run security:gitleaks:staged && npm run security:custom:staged",
    "prepush:strict": "npm run guard:all",
    "test:all": "bash scripts/run-all-tests.sh",
    "test:customer-journey": "ts-node --project scripts/tsconfig.json scripts/e2e/user-customer-journey.test.ts",
    "test:owner-journey": "ts-node --project scripts/tsconfig.json scripts/e2e/user-owner-journey.test.ts",
    "test:booking-flow": "ts-node --project scripts/tsconfig.json scripts/e2e/user-booking-flow.test.ts",
    "test:payment-flow": "ts-node --project scripts/tsconfig.json scripts/e2e/user-payment-flow.test.ts",
    "test:admin-journey": "ts-node --project scripts/tsconfig.json scripts/e2e/user-admin-journey.test.ts",
    "test:admin-as-customer": "ts-node --project scripts/tsconfig.json scripts/e2e/user-admin-as-customer.test.ts",
    "test:admin-as-owner": "ts-node --project scripts/tsconfig.json scripts/e2e/user-admin-as-owner.test.ts",
    "test:concurrent-ops": "ts-node --project scripts/tsconfig.json scripts/e2e/user-concurrent-operations.test.ts",
    "test:stress-booking": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/e2e/stress-booking-runner.ts",
    "test:slot-management": "ts-node --project scripts/tsconfig.json scripts/e2e/user-slot-management.test.ts",
    "test:slots-rls": "ts-node --project scripts/tsconfig.json scripts/integration/slots-rls-policies.test.ts",
    "test:bookings-rls": "ts-node --project scripts/tsconfig.json scripts/integration/bookings-rls-policies.test.ts",
    "test:secure-action-link": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/security/secure-action-link-hardening.test.ts",
    "test:error-scenarios": "ts-node --project scripts/tsconfig.json scripts/e2e/user-error-scenarios.test.ts",
    "test:edge-cases": "ts-node --project scripts/tsconfig.json scripts/e2e/edge-cases-comprehensive.test.ts",
    "test:slot-service": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/e2e/slot-service-comprehensive.test.ts",
    "test:phase1": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/schema-validation.test.ts",
    "test:phase2": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/integration/atomic-booking-transactions.test.ts",
    "test:realtime-slot-updates": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/integration/integration-realtime-slot-updates.test.ts",
    "test:phase3": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/state-machines.test.ts",
    "test:phase4": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/security/payment-safety.test.ts",
    "test:phase5": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/security/rbac-authorization.security.ts",
    "test:phase6": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/security/abuse-rate-limiting.security.ts",
    "test:phase7": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/config-env-safety.test.ts",
    "test:phase8": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/e2e/audit-logging.test.ts",
    "test:phase9": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/e2e/e2e-flows.test.ts",
    "test:unit": "npx dotenv-cli -e .env.test -- ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/run-unit-tests.ts",
    "test:unit:vitest": "npx dotenv-cli -e .env.test -- npx vitest run --config vitest.unit.config.mts --coverage",
    "test:coverage:test-classes": "npx dotenv-cli -e .env.test -- npx vitest run --config vitest.coverage-test-files.config.mts --coverage",
    "test:coverage:all": "npm run test:unit:vitest && npm run test:coverage:test-classes",
    "test:api-health": "npx dotenv-cli -e .env.test -- ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/api-routes/api-health-route.test.ts",
    "test:api-routes": "npx dotenv-cli -e .env.test -- npx vitest run --config vitest.config.mts",
    "test:unit-services": "npx dotenv-cli -e .env.test -- npx vitest run scripts/unit-services --config vitest.config.mts",
    "test:unit-repositories": "npx dotenv-cli -e .env.test -- npx vitest run scripts/unit-repositories --config vitest.config.mts",
    "test:unit-config": "npx dotenv-cli -e .env.test -- npx vitest run scripts/unit-config --config vitest.config.mts",
    "test:unit-middleware": "npx dotenv-cli -e .env.test -- npx vitest run scripts/unit-middleware --config vitest.config.mts",
    "test:database-connection-pool": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/integration/database-connection-pool.test.ts",
    "test:database-migrations": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/integration/database-migrations.test.ts",
    "test:unit-database": "npx vitest run scripts/unit-database --config vitest.config.mts",
    "test:unit:utils": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-utils-string.test.ts && ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-utils-time.test.ts && ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-utils-validation.test.ts",
    "test:unit:state": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-state-machines-pure.test.ts",
    "test:unit:security": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-utils-security.test.ts && ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-input-sanitizer.test.ts && ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-input-filter.test.ts && ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-csrf.test.ts",
    "test:unit:policies": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/unit-utils/unit-config-policies.test.ts",
    "test:unit:routing": "ts-node scripts/unit-utils/unit-routing.test.ts",
    "test:unit:geocoding": "ts-node scripts/unit-utils/unit-geocoding.test.ts",
    "security-check": "node scripts/infrastructure/security-check-pre-push.js",
    "test:unit:coverage": "SALON_TOKEN_SECRET=test-secret c8 --reporter=text --reporter=html --include='lib/**/*.ts' --include='config/**/*.ts' --include='types/**/*.ts' --exclude='**/*.test.ts' --exclude='**/*.security.ts' --exclude='scripts/**' ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/run-unit-tests.ts",
    "test:integration": "npx vitest run scripts/unit-database scripts/integration --config vitest.config.mts",
    "test:crud": "npx dotenv-cli -e .env.test -- npx vitest run scripts/unit-repositories --config vitest.config.mts --passWithNoTests && npx dotenv-cli -e .env.test -- ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/integration/database-migrations.test.ts",
    "test:security:vitest": "npx vitest run scripts/security --config vitest.config.mts --passWithNoTests",
    "test:e2e:vitest": "npx vitest run scripts/e2e --config vitest.config.mts --passWithNoTests",
    "quality:license": "node scripts/infrastructure/run-license-check.js",
    "quality:depcheck": "depcheck . --specials=eslint,typescript --ignores=@types/*,eslint*,prettier,@cyclonedx/*,detect-secrets,c8,vitest,ts-node,tsconfig-paths,lint-staged,husky,dotenv-cli,postcss,autoprefixer,@svgr/webpack,@vitest/coverage-v8,depcheck,license-checker,ts-prune,@swc/helpers",
    "quality:ts-prune": "ts-prune --project tsconfig.json -e",
    "quality:bundle-size": "node scripts/infrastructure/run-bundle-size-check.js",
    "ci:lockfile": "node scripts/infrastructure/check-lockfile.js"
  },
  "dependencies": {
    "@supabase/postgrest-js": "^2.99.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.38.0",
    "@swc/helpers": "^0.5.20",
    "@tanstack/react-virtual": "^3.13.22",
    "@tremor/react": "^3.18.7",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^1.6.1",
    "bullmq": "^5.71.0",
    "chart.js": "^4.5.1",
    "framer-motion": "^12.34.3",
    "ioredis": "^5.10.0",
    "lodash": "4.18.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "node-fetch": "^3.3.2",
    "osm-pbf-parser": "^2.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "swagger-ui-react": "^5.17.10",
    "uuidv7": "^1.1.0",
    "web-vitals": "^5.1.0",
    "zod": "^3.22.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.1.1",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.0",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.0",
    "c8": "^10.0.0",
    "depcheck": "^1.4.7",
    "detect-secrets": "^1.0.6",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.5.12",
    "husky": "^9.0.0",
    "license-checker": "^25.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
